# Frontend env for Next.js (also set in Vercel → Environment Variables)

# Cesium globe (required)
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# Bundled demo is ON by default (frontend/demo-data/*.json baked into build).
# Only set to false when pointing at a live FastAPI backend:
# NEXT_PUBLIC_DEMO_MODE=false
# NEXT_PUBLIC_API_URL=https://your-api.example.com
