# Frontend env for Next.js (also set these in Vercel → Project → Environment Variables)

# Cesium globe (required)
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# Static demo — JSON is bundled from frontend/demo-data/ at build time.
# Enabled automatically when API URL is localhost, or set explicitly:
NEXT_PUBLIC_DEMO_MODE=true

# Only needed when connecting to a live FastAPI backend (set DEMO_MODE=false):
# NEXT_PUBLIC_API_URL=https://your-api.onrender.com
