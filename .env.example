POSTGRES_DB=helios
POSTGRES_USER=helios
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://helios:changeme@postgres:5432/helios
DATABASE_URL_SYNC=postgresql://helios:changeme@postgres:5432/helios
REDIS_URL=redis://redis:6379/0
TRITON_URL=triton:8000
JWT_SECRET=change-me-in-production

# Copernicus Data Space (https://dataspace.copernicus.eu)
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=
COPERNICUS_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
COPERNICUS_STAC_URL=https://catalogue.dataspace.copernicus.eu/stac/search
COPERNICUS_S3_CREDENTIALS_URL=https://eodata.dataspace.copernicus.eu/s3-credentials
COPERNICUS_S3_ENDPOINT=https://eodata.dataspace.copernicus.eu

# Planet Labs (https://planet.com)
PLANET_API_KEY=
PLANET_API_BASE=https://api.planet.com

# Storage paths (inside containers)
DATA_ROOT=/data
TILES_DIR=/tiles
DEM_PATH=/data/dem/srtm_30m.tif
MAX_CLOUD_COVER=0.30
TILE_SIZE=640
TILE_OVERLAP=0.20

# Phase 3 — ML training (host WSL2) + Triton
KAGGLE_USERNAME=
KAGGLE_KEY=
ML_DATA_DIR=./ml/datasets
YOLO_MODEL_SIZE=s
YOLO_CONFIDENCE_MIN=0.25
NMS_IOU_THRESHOLD=0.45
MSTAR_CONFIDENCE_MIN=0.50
BIT_CHANGE_THRESHOLD=0.50
DETECTIONS_DIR=/data/detections
YOLO_WEIGHTS_PATH=/ml/artifacts/yolo/best.pt
TRITON_YOLO_MODEL=yolov8_detection
TRITON_MSTAR_MODEL=mstar_sar
TRITON_BIT_MODEL=bit_change

CESIUM_ION_TOKEN=
